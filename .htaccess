RewriteEngine On

# Redirect www to non-www
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Ensure HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Block public access to CSV backups and JSON configs
<Files "enquiries_backup_9418.csv">
  Order Allow,Deny
  Deny from all
</Files>
<Files "admin_config_9418.json">
  Order Allow,Deny
  Deny from all
</Files>
